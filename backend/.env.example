# ============================================================
# VARIÁVEIS DE AMBIENTE — Configurações do Backend
# ============================================================
# O QUE FAZER AQUI:
# 1. Copia este ficheiro e renomeia a cópia para ".env"
# 2. Preenche os valores conforme o teu ambiente
# 3. O ficheiro .env NUNCA deve ser enviado para o Git
#    (já está no .gitignore)
#
# COMO USAR:
#   No terminal: copy .env.example .env  (Windows)
#   Depois edita o .env com os teus valores
# ============================================================

# Porta onde o servidor vai correr
PORT=3000

# Configuração da Base de Dados PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=notificacoes_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres123

# Segredo para gerar tokens JWT (autenticação)
# IMPORTANTE: Em produção, usar uma string longa e aleatória
JWT_SECRET=mudar-este-segredo-em-producao
JWT_EXPIRATION=24h

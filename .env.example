# ============================================================
# VARIÁVEIS DE AMBIENTE — Copia este ficheiro para .env
# ============================================================
# Encontras estes valores no dashboard do Supabase:
#   Settings → API → URL e Keys

SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...sua-service-role-key...
SUPABASE_ANON_KEY=eyJ...sua-anon-key...

# Segredo para assinar os tokens JWT (usa uma string longa e aleatória)
JWT_SECRET=muda-este-segredo-para-algo-muito-longo-e-aleatorio
